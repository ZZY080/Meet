{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@components/*": ["./components/*"],
      "@locales/*": ["./locales/*"],
      "@type/*": ["./type/*"],
      "@utils/*": ["./utils/*"],
      "@configs/*": ["./configs/*"],
      "@redux/*": ["./redux/*"],
      "@constants/*": ["./constants/*"],
      "@contexts/*": ["./contexts/*"],
      "@api/*": ["./api/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
